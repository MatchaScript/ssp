{
	"name": "@matchalatte/ssp-core",
	"version": "0.0.1",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./generate": {
			"types": "./dist/generate.d.ts",
			"default": "./dist/generate.js"
		},
		"./tokens/semantic.json": "./src/tokens/semantic.json",
		"./tokens/palette.json": "./src/tokens/palette.json"
	},
	"files": [
		"dist",
		"src/tokens"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"extract-tokens": "node --experimental-strip-types scripts/extract-tokens.ts"
	},
	"dependencies": {
		"@adobe/leonardo-contrast-colors": "^1.1.0",
		"culori": "^4.0.2"
	},
	"peerDependencies": {
		"vite": ">=5.0.0"
	},
	"devDependencies": {
		"@adobe/spectrum-tokens": "^14.6.0"
	}
}

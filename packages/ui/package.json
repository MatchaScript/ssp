{
	"name": "@matchalatte/ssp-ui",
	"version": "0.0.2-next.5",
	"license": "MIT",
	"author": "MatchaScript",
	"homepage": "https://github.com/MatchaScript/ssp#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MatchaScript/ssp.git",
		"directory": "packages/ui"
	},
	"bugs": {
		"url": "https://github.com/MatchaScript/ssp/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components/*": {
			"types": "./dist/components/*/index.d.ts",
			"svelte": "./dist/components/*/index.js",
			"default": "./dist/components/*/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"!dist/**/*.stories.*",
		"!dist/**/*.spec.*",
		"!dist/**/*.test.*",
		"!dist/**/*.spec-harness.*",
		"!dist/styles/spectrum.css"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm run package",
		"package": "svelte-kit sync && svelte-package",
		"prepublishOnly": "pnpm run package",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "pnpm test:unit -- --run",
		"test:unit": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"bits-ui": "^2.18.1",
		"lucide": "^1.14.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.2",
		"@matchalatte/ssp-theme": "workspace:*",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.6",
		"@storybook/addon-docs": "^10.3.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.6",
		"@storybook/sveltekit": "^10.3.6",
		"@sveltejs/adapter-node": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/package": "catalog:",
		"@types/node": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"eslint-plugin-storybook": "^10.3.6",
		"playwright": "catalog:",
		"storybook": "^10.3.6",
		"svelte-check": "catalog:",
		"vitest": "catalog:",
		"vitest-browser-svelte": "catalog:"
	}
}

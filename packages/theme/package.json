{
	"name": "@matchalatte/ssp-theme",
	"version": "0.0.2-next.2",
	"license": "MIT",
	"author": "MatchaScript",
	"homepage": "https://github.com/MatchaScript/ssp#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MatchaScript/ssp.git",
		"directory": "packages/theme"
	},
	"bugs": {
		"url": "https://github.com/MatchaScript/ssp/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./generate": {
			"types": "./dist/generate.d.ts",
			"default": "./dist/generate.js"
		},
		"./tokens/semantic.json": "./src/tokens/semantic.json",
		"./tokens/palette.json": "./src/tokens/palette.json"
	},
	"files": [
		"dist",
		"src/tokens"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"extract-tokens": "node --experimental-strip-types scripts/extract-tokens.ts"
	},
	"dependencies": {
		"@adobe/leonardo-contrast-colors": "^1.1.0",
		"culori": "^4.0.2"
	},
	"devDependencies": {
		"@adobe/spectrum-tokens": "^14.7.0",
		"vite": "catalog:"
	}
}
